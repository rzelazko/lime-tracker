// For format details, see https://aka.ms/devcontainer.json.
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node.
{
  "name": "Debian Devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "mounts": ["source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"],
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "Angular.ng-template",
        "manux54.angular-localization-helper",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions"
      ]
    }
  },
  "remoteEnv": {
    "CHROME_BIN": "/usr/bin/chromium",
    "SHELL": "/bin/bash"
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [4000, 4200, 4400, 8080, 9099, 5005],

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "bash -c 'source /usr/local/share/nvm/nvm.sh && nvm install && nvm use && npm install && npx ng completion'",

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  "remoteUser": "root"
}
